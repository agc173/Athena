rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Daily (se mantiene patrón existente: lectura autenticada).
    match /horoscopeDaily/{dateIso}/signs/{sign} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /langs/{lang} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // Weekly: permitir lectura autenticada de doc canónico y variantes por idioma.
    match /horoscopeWeekly/{weekKey}/signs/{sign} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /langs/{lang} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // Monthly: permitir lectura autenticada de doc canónico y variantes por idioma.
    match /horoscopeMonthly/{monthKey}/signs/{sign} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /langs/{lang} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // User-owned docs (scope limitado a rutas que la app usa desde cliente).
    match /users/{uid}/profile/current {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/birthEssence/current {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/dailyRitual/current {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/habits/current {
      allow read, write: if isOwner(uid);
    }

    // Tarot deck progression es user-owned y de solo lectura desde cliente.
    // Writes quedan backend-owned (Admin SDK), por eso se niegan aquí.
    match /users/{uid}/tarotDeckProgress/{trackId} {
      allow get, list: if isOwner(uid);
      allow write: if false;

      // Permite leer/listar cartas desbloqueadas del owner únicamente.
      match /unlockedCards/{cardId} {
        allow get, list: if isOwner(uid);
        allow write: if false;
      }
    }

    // Username index is backend-owned for writes (Functions/Admin SDK), readable for checks.
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Default deny para evitar aperturas accidentales de otras colecciones (users/economy/etc).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
